{
  "manifest_version": 3,
  "name": "Pomodoro GitHub",
  "description": "Developer-focused Pomodoro timer with GitHub integration",
  "version": "1.0.0",
  "permissions": ["alarms", "notifications", "storage", "identity"],
  "host_permissions": ["https://api.github.com/*"],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/tomato16.png",
      "48": "icons/tomato48.png",
      "128": "icons/tomato128.png"
    }
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "icons": {
    "16": "icons/tomato16.png",
    "48": "icons/tomato48.png",
    "128": "icons/tomato128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self' 'unsafe-inline'"
  }
}
